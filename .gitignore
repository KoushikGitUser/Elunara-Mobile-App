.idea/

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# generated native folders — track sources, ignore build artifacts
android/app/build/
android/.gradle/
android/local.properties

# iOS — track sources, ignore build artifacts and pods
ios/Pods/
ios/build/
ios/DerivedData/
ios/.xcode.env.local
ios/**/xcuserdata/
ios/**/project.xcworkspace/xcuserdata/
*.hmap
*.ipa
*.xcuserstate
*.dSYM
*.dSYM.zip

# System files
nul
